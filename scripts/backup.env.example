# Copia este archivo a `backup.env` (no se versiona) y completa los valores.
# Cargado automáticamente por scripts/backup.sh.

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_HOST=100.87.26.105
MYSQL_PORT=3306
MYSQL_USER=ThinWallet
MYSQL_PASSWORD=<<SET_IN_VPS>>
MYSQL_DB=thinwallet_db

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://hernando:<<SET_IN_VPS>>@100.124.143.126:27017/?authSource=admin
MONGO_DB=gestion_gastos_audit

# ── Retención y destino ─────────────────────────────────────────────────────
