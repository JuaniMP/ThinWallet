# ============================================================
# ThinWallet Backend — Variables de entorno requeridas
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# Base de datos MySQL
MYSQL_URL=jdbc:mysql://HOST:3306/thinwallet_db
MYSQL_USERNAME=tu_usuario_mysql
MYSQL_PASSWORD=tu_password_mysql

# MongoDB
MONGODB_URI=mongodb://usuario:password@HOST:27017/thinwallet_db?authSource=admin
MONGODB_DATABASE=thinwallet_db

# Correo (Gmail App Password)
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_gmail

# Clave maestra AES-256 para cifrado — mínimo 32 caracteres aleatorios
THINWALLET_CIPHER_MASTER_KEY=cambia-esto-por-una-clave-aleatoria-segura-32chars

# JWT — secreto para firmar tokens (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-seguro-minimo32chars

# CORS — orígenes permitidos (separados por coma, sin espacios)
# Desarrollo: http://localhost:5173
# Producción: añade tu dominio Vercel, ej: https://thinwallet.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Firebase Cloud Messaging (push notifications)
# 1. Ve a Firebase Console → Configuración del proyecto → Cuentas de servicio
# 2. Genera nueva clave privada → descarga el JSON
# 3. Convierte a base64: base64 -i serviceAccountKey.json (Linux/Mac)
#    En Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))
FIREBASE_ENABLED=true
FIREBASE_SERVICE_ACCOUNT_BASE64=pega_aqui_el_base64_del_service_account_json
